/* frontend/src/components/FeedbackWidget.css */

.feedback-widget {
  position: relative;
}

/* Trigger Button */
.feedback-trigger {
  padding: 10px 18px;
  background: linear-gradient(135deg, #0ea5a0, #0891b2);
  color: white;
  border: none;
  border-radius: 100px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: all 0.2s;
  box-shadow: 0 2px 8px rgba(14, 165, 160, 0.3);
}

.feedback-trigger:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(14, 165, 160, 0.4);
}

.feedback-trigger:active {
  transform: translateY(0);
}

/* Modal Overlay */
.feedback-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 22, 35, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* Modal */
.feedback-modal {
  background: white;
  border-radius: 16px;
  padding: 32px;
  max-width: 500px;
  width: 100%;
  box-shadow: 0 24px 64px rgba(15, 22, 35, 0.2);
  position: relative;
  animation: slideUp 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Close Button */
.feedback-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 32px;
  height: 32px;
  border: none;
  background: #f7f8fa;
  border-radius: 50%;
  font-size: 18px;
  color: #718096;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.feedback-close:hover {
  background: #e4e9f0;
  color: #0f1623;
}

/* Title */
.feedback-title {
  font-family: 'Instrument Serif', serif;
  font-size: 24px;
  font-weight: 400;
  color: #0f1623;
  margin-bottom: 6px;
}

.feedback-subtitle {
  font-size: 14px;
  color: #718096;
  margin-bottom: 24px;
}

/* Form Fields */
.feedback-field {
  margin-bottom: 20px;
}

.feedback-field label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #0f1623;
  margin-bottom: 8px;
}

/* Star Rating */
.star-rating {
  display: flex;
  gap: 8px;
}

.star {
  background: none;
  border: none;
  font-size: 32px;
  color: #e4e9f0;
  cursor: pointer;
  transition: all 0.2s;
  padding: 0;
}

.star:hover,
.star.active {
  color: #f59e0b;
  transform: scale(1.1);
}

.rating-label {
  font-size: 13px;
  font-weight: 600;
  color: #0ea5a0;
  margin-top: 8px;
}

/* Select & Textarea */
.feedback-field select,
.feedback-field textarea {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid #e4e9f0;
  border-radius: 8px;
  font-family: 'Figtree', sans-serif;
  font-size: 14px;
  color: #0f1623;
  transition: all 0.2s;
  background: white;
}

.feedback-field select:focus,
.feedback-field textarea:focus {
  outline: none;
  border-color: #0ea5a0;
  box-shadow: 0 0 0 3px rgba(14, 165, 160, 0.1);
}

.feedback-field textarea {
  resize: vertical;
  line-height: 1.6;
}

.char-count {
  font-size: 11px;
  color: #a0aec0;
  text-align: right;
  margin-top: 4px;
}

/* Submit Button */
.feedback-submit {
  width: 100%;
  padding: 12px 20px;
  background: #0ea5a0;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.2s;
}

.feedback-submit:hover:not(:disabled) {
  background: #0c8b87;
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(14, 165, 160, 0.3);
}

.feedback-submit:active:not(:disabled) {
  transform: translateY(0);
}

.feedback-submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.spinner {
  width: 14px;
  height: 14px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Success State */
.feedback-success {
  text-align: center;
  padding: 40px 20px;
}

.success-icon {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #10b981, #059669);
  color: white;
  font-size: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
  animation: scaleIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes scaleIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.feedback-success h3 {
  font-family: 'Instrument Serif', serif;
  font-size: 22px;
  font-weight: 400;
  color: #0f1623;
  margin-bottom: 8px;
}

.feedback-success p {
  font-size: 14px;
  color: #718096;
}

/* Responsive */
@media (max-width: 640px) {
  .feedback-modal {
    padding: 24px 20px;
  }

  .feedback-title {
    font-size: 20px;
  }

  .star {
    font-size: 28px;
  }
}
