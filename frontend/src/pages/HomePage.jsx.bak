function CheckIcon({ size = 8, color = "#fff" }) {
  return (
    <svg width={size} height={size} viewBox="0 0 10 10" fill="none">
      <path d="M2 5l2.5 2.5L8 3" stroke={color} strokeWidth="1.6" strokeLinecap="round" strokeLinejoin="round" />
    </svg>
  );
}

function ArrowIcon() {
  return (
    <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
      <path d="M3 7.5h9M8 3.5l4 4-4 4" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round" />
    </svg>
  );
}

function SparkIcon() {
  return (
    <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
      <path d="M8 1v3M8 12v3M1 8h3M12 8h3M3.5 3.5l2.1 2.1M10.4 10.4l2.1 2.1M10.4 5.6l2.1-2.1M3.5 12.5l2.1-2.1" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" />
    </svg>
  );
}

function SendIcon() {
  return (
    <svg width="11" height="11" viewBox="0 0 14 14" fill="none">
      <path d="M13 1L6 8M13 1l-4 11-3-5-5-3 11-3z" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" strokeLinejoin="round" />
    </svg>
  );
}

function LogoMark() {
  return (
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <rect x="2" y="2" width="5" height="5" rx="1.5" fill="white" />
      <rect x="9" y="2" width="5" height="5" rx="1.5" fill="white" opacity="0.6" />
      <rect x="2" y="9" width="5" height="5" rx="1.5" fill="white" opacity="0.6" />
      <rect x="9" y="9" width="5" height="5" rx="1.5" fill="white" />
    </svg>
  );
}

export default function HomePage() {
  const navigate = useNavigate()
  const [activeReview, setActiveReview] = useState(null);

  return (
    <>
      <style>{styles}</style>

      {/* ── Navbar ─────────────────────────────────────── */}
      <nav className="nav">
        <div className="nav-inner">
          <a href="#" className="nav-logo">
            <div className="nav-logo-icon">
              <LogoMark />
            </div>
            ReviewPilot
          </a>
          <div className="nav-links">
            <button className="nav-link">Features</button>
            <button className="nav-link">Pricing</button>
            <button className="nav-link">How it works</button>
          </div>
          <div className="nav-actions">
            <button className="btn-nav-login">Login</button>
            <button className="btn-nav-cta">
              Get started <ArrowIcon />
            </button>
          </div>
        </div>
      </nav>

      {/* ── Hero ───────────────────────────────────────── */}
      <section className="hero">
        <div className="hero-bg" />
        <div className="hero-inner">

          {/* Left */}
          <div className="hero-left">
            <div className="hero-badge anim-fade-up">
              <span className="hero-badge-dot" />
              AI-powered review management
            </div>

            <h1 className="hero-headline anim-fade-up d1">
              Reply to Google Reviews<br />
              in <em>Seconds</em> Using AI
            </h1>

            <p className="hero-sub anim-fade-up d2">
              Automatically generate polite, professional replies to customer reviews
              and post them with one click.
            </p>

            <ul className="hero-steps">
              {[
                "Connect your Google Business Profile",
                "Generate AI replies",
                "Approve & publish instantly",
              ].map((step, i) => (
                <li
                  key={i}
                  className="hero-step"
                  style={{ animationDelay: `${0.24 + i * 0.08}s` }}
                >
                  <div className="hero-step-num">{i + 1}</div>
                  {step}
                </li>
              ))}
            </ul>

            <div className="hero-cta anim-fade-up d4">
              <button className="btn-primary">
                Get Started <ArrowIcon />
              </button>
              <button className="btn-secondary">
                Login
              </button>
            </div>

            <div className="hero-trust anim-fade-up d5">
              {["Free 10 replies", "No credit card", "2-min setup"].map((t) => (
                <span key={t} className="hero-trust-item">
                  <span className="hero-trust-check">
                    <CheckIcon size={7} />
                  </span>
                  {t}
                </span>
              ))}
            </div>
          </div>

          {/* Right — product preview */}
          <div className="hero-right anim-fade-in d3">
            {/* Floating badge */}
            <div className="preview-badge">
              <div className="preview-badge-icon">
                <CheckIcon size={13} />
              </div>
              <div>
                <div>Reply posted to Google</div>
                <div className="preview-badge-sub">Just now · 4.9★ response rate</div>
              </div>
            </div>

            <div className="preview-shell">
              {/* Chrome */}
              <div className="preview-chrome">
                <div className="chrome-dot chrome-dot-r" />
                <div className="chrome-dot chrome-dot-y" />
                <div className="chrome-dot chrome-dot-g" />
                <div className="chrome-url">app.reviewpilot.com/reviews</div>
              </div>

              {/* Body */}
              <div className="preview-body">
                <div className="preview-title">Reviews Inbox</div>

                {REVIEWS.map((r) => (
                  <div
                    key={r.id}
                    className="review-item"
                    onClick={() => setActiveReview(activeReview === r.id ? null : r.id)}
                    style={{ cursor: "pointer" }}
                  >
                    <div className="review-top">
                      <div className="review-author-row">
                        <div
                          className="review-avatar"
                          style={{ background: r.avatar }}
                        >
                          {r.author[0]}
                        </div>
                        <div>
                          <div className="review-author">{r.author}</div>
                          <div className="review-stars" style={{ color: "#f59e0b" }}>
                            {r.stars}
                          </div>
                        </div>
                      </div>
                      <span
                        className={`status-pill ${
                          r.status === "replied"
                            ? "status-replied"
                            : r.status === "ai"
                            ? "status-ai"
                            : "status-pending"
                        }`}
                      >
                        {r.status === "replied"
                          ? "✓ Replied"
                          : r.status === "ai"
                          ? "AI Ready"
                          : "Needs reply"}
                      </span>
                    </div>

                    <p className="review-text">{r.text}</p>

                    {/* Reply bubble for replied reviews */}
                    {r.reply && (
                      <div className="reply-bubble">{r.reply}</div>
                    )}

                    <div className="review-footer">
                      <span className="review-date">{r.date}</span>
                      {r.status === "pending" && (
                        <button
                          className="review-action-btn btn-generate"
                          onClick={(e) => e.stopPropagation()}
                        >
                          <SparkIcon /> Generate
                        </button>
                      )}
                      {r.status === "ai" && (
                        <button
                          className="review-action-btn btn-post"
                          onClick={(e) => e.stopPropagation()}
                        >
                          <SendIcon /> Post reply
                        </button>
                      )}
                    </div>
                  </div>
                ))}

                {/* Stats */}
                <div className="preview-stats">
                  {[
                    { val: "47", lbl: "Reviews synced" },
                    { val: "4.8★", lbl: "Avg. rating" },
                    { val: "94%", lbl: "Reply rate" },
                  ].map((s) => (
                    <div key={s.lbl} className="stat-item">
                      <div className="stat-val">{s.val}</div>
                      <div className="stat-lbl">{s.lbl}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ── Social proof strip ─────────────────────────── */}
      <div className="social-strip">
        <div className="social-strip-inner">
          <span className="social-label">Trusted by local businesses</span>
          <div className="social-divider" />
          <div className="social-items">
            {[
              { icon: "☕", name: "Bloom Café" },
              { icon: "🚗", name: "Riverside Auto" },
              { icon: "💆", name: "Lotus Spa" },
              { icon: "🍕", name: "Napoli Kitchen" },
              { icon: "🏋️", name: "FitCore Gym" },
            ].map((b) => (
              <div key={b.name} className="social-item">
                <div
                  className="social-item-icon"
                  style={{ background: "#f1f5f9" }}
                >
                  {b.icon}
                </div>
                {b.name}
              </div>
            ))}
          </div>
        </div>
      </div>
    </>
  );
}
